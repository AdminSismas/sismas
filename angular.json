{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,

  "newProjectRoot": "projects",
  "projects": {
    "geoGestion": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "vex",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": {
              "base": "dist",
              "browser": ""
            },
            "index": "src/index.html",
            "polyfills": [
              "src/polyfills.ts"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              "src/_redirects",
              "src/README.md",
              "src/CHANGELOG.md",
              {
                "glob": "**/*.svg",
                "input": "node_modules/@material-design-icons/svg",
                "output": "assets/img/icons/material-design-icons/"
              }
            ],
            "styles": [
              "src/styles.scss",
              "src/@vex/styles/tailwind.scss"
            ],

            "scripts": [],
            "allowedCommonJsDependencies": [
              "@mattlewis92/dom-autoscroller",
              "angular-calendar/date-adapters/date-fns",
              "apexcharts",
              "calendar-utils/date-adapters/date-fns",
              "can-use-dom",
              "core-js",
              "dom-plane",
              "dom-set",
              "faker",
              "file-saver",
              "highlight.js",
              "lodash.debounce",
              "lodash.memoize",
              "lodash.throttle",
              "lodash/debounce.js",
              "lodash/throttle.js",
              "luxon",
              "moment",
              "quill-delta",
              "quill",
              "seedrandom",
              "showdown",
              "simplebar",
              "sweetalert2"
            ],
            "extractLicenses": false,
            "sourceMap": true,
            "optimization": false,
            "namedChunks": true,
            "browser": "src/main.ts"
          },
          "configurations": {
            "production": {
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true
                }
              },
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "5mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environments.ts",
                  "with": "src/environments/environments.prod.ts"
                }
              ]
            },
            "armenia": {
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true
                }
              },
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "5mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environments.ts",
                  "with": "src/environments/environments.armenia.ts"
                }
              ]
            },
            "calarca": {
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true
                }
              },
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "5mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environments.ts",
                  "with": "src/environments/environments.calarca.ts"
                }
              ]
            },
            "manizales": {
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true
                }
              },
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "5mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environments.ts",
                  "with": "src/environments/environments.manizales.ts"
                }
              ]
            },
            "masora": {
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true
                }
              },
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "5mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environments.ts",
                  "with": "src/environments/environments.masora.ts"
                }
              ]
            },
            "filandia": {
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true
                }
              },
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "5mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environments.ts",
                  "with": "src/environments/environments.filandia.ts"
                }
              ]
            },
            "barrancabermeja": {
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true
                }
              },
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "5mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environments.ts",
                  "with": "src/environments/environments.barrancabermeja.ts"
                }
              ]
            },
            "quimbaya": {
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true
                }
              },
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "5mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environments.ts",
                  "with": "src/environments/environments.quimbaya.ts"
                }
              ]
            },
            "montenegro": {
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true
                }
              },
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "5mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environments.ts",
                  "with": "src/environments/environments.montenegro.ts"
                }
              ]
            },
            "test": {
              "optimization": false,
              "outputHashing": "all",
              "sourceMap": true,
              "namedChunks": true,
              "extractLicenses": false,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "8mb",
                  "maximumError": "10mb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environments.ts",
                  "with": "src/environments/environments.test.ts"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "geoGestion:build",
            "proxyConfig": "proxy.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "geoGestion:build:production"
            },
            "armenia": {
              "buildTarget": "geoGestion:build:armenia"
            },
            "manizales": {
              "buildTarget": "geoGestion:build:manizales"
            },
            "masora": {
              "buildTarget": "geoGestion:build:masora"
            },
            "filandia": {
              "buildTarget": "geoGestion:build:filandia"
            },
            "barrancabermeja": {
              "buildTarget": "geoGestion:build:barrancabermeja"
            },
            "quimbaya": {
              "buildTarget": "geoGestion:build:quimbaya"
            },
            "montenegro": {
              "buildTarget": "geoGestion:build:montenegro"
            },
            "test": {
              "buildTarget": "geoGestion:build:test"
            }

          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "geoGestion:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:jest",
          "options": {
            "tsConfig": "tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "src/**/*.ts",
              "src/**/*.html"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false,
    "schematicCollections": [
      "angular-eslint"
    ]
  }
}
