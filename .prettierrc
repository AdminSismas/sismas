{
  "singleQuote": true,
  "bracketSameLine": false,
  "trailingComma": "none",
  "semi": false,
  "singleAttributePerLine": true,
  "overrides": [
    {
      "files": [
        "**/*.css",
        "**/*.scss",
        "**/*.html"
      ],
      "options": {
        "singleQuote": false
      }
    }
  ]
}
