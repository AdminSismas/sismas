{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": ".",
    "outDir": "dist",
    "paths": {
      "@/*": ["src/*"],
      "@lib/*": ["src/lib/*"]
    }
  },
  "include": [
    "src",
    "astro.config.mjs",
    "tailwind.config.mjs",
    "eslint.config.js"
  ]
}
