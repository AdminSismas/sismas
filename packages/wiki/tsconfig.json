{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": ".",
    "outDir": "dist",
    "paths": {
      "@/*": ["src/*"],
      "@lib/*": ["src/lib/*"],
      "@components/*": ["src/components/*"],
      "@assets/*": ["src/assets/*"]
    }
  },
  "plugins": [
    {
      "name": "@astrojs/ts-plugin"
    }
  ],
  "exclude": ["dist"],
  "include": [
    "db/*",
    "src",
    "src/env.d.ts",
    "astro.config.mjs",
    "tailwind.config.mjs",
    "eslint.config.js",
    ".astro/types.d.ts"
  ]
}
