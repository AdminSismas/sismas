---
import Layout from '@/layouts/Layout.astro';
import WikiEditor from '@components/admin/WikiEditor';

export const prerender = false; // SSR Mode
---

<Layout title="Admin Editor">
  <div class="mb-6">
    <h1 class="text-3xl font-bold tracking-tight">Editor de Contenido</h1>
    <p class="text-muted-foreground">Crea o edita artículos del manual.</p>
  </div>

  <!-- 
		React Island: client:only ensures it renders only on the client.
		This isolates the heavy editor logic from the server-rendered public pages.
	-->
  <WikiEditor client:only="react" />
</Layout>
