---
import Layout from '@/layouts/Layout.astro';
import { wikiRepository } from '@lib/db/db';
import { marked } from 'marked';

export const prerender = false; // SSR Mode

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const article = await wikiRepository.getArticle(slug);

if (!article) {
  return Astro.redirect('/404');
}

const contentHtml = marked.parse(article.content);
---

<Layout title={article.title}>
  <div class="max-w-3xl mx-auto">
    <div class="mb-8 border-b border-border pb-4">
      <h1 class="text-4xl font-extrabold tracking-tight lg:text-5xl mb-2">
        {article.title}
      </h1>
      <div class="flex items-center text-sm text-muted-foreground">
        <span class="mr-4">Autor: {article.author}</span>
        <span
          >Actualizado: {
            new Date(article.updatedAt ?? '').toLocaleDateString()
          }</span
        >
      </div>
    </div>

    <div
      class="prose prose-slate dark:prose-invert max-w-none break-words"
      set:html={contentHtml}
    />
  </div>
</Layout>