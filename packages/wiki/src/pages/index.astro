---
import Layout from '@/layouts/Layout.astro';
import { stripMarkdown } from '@lib/strip-markdown';
import { wikiRepository, type WikiArticle } from '@lib/db/db';
import { ErrorAlert } from '@components/ErrorAlert';

let articles: WikiArticle[] = [];
let fetchError: string | null = null;

try {
  articles = await wikiRepository.listArticles();
} catch (error) {
  console.error('Error fetching articles:', error);
  fetchError = error instanceof Error ? error.message : 'Error desconocido';
}
---

<Layout title="Manual Sismas">
  <ErrorAlert
    client:load
    error={fetchError}
  />
  <div class="space-y-6">
    <div class="space-y-2">
      <h1 class="text-3xl font-extrabold tracking-tight lg:text-5xl">
        Documentación
      </h1>
      <p class="text-muted-foreground">
        Bienvenido al sistema de documentación de Sismas.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        articles &&
          articles.map((article: WikiArticle) => (
            <a
              href={`/wiki/manual/${article.slug}`}
              class="group relative flex flex-col space-y-2 rounded-lg border p-5 hover:bg-accent hover:text-accent-foreground transition-colors"
            >
              <h2 class="font-semibold tracking-tight">{article.title}</h2>
              <p class="text-sm text-muted-foreground line-clamp-3">
                {stripMarkdown(article.content).substring(0, 150)}...
              </p>
              <div class="flex items-center text-xs text-muted-foreground mt-auto pt-2">
                <span>
                  Actualizado:{' '}
                  {new Date(article.updatedAt ?? '').toLocaleDateString()}
                </span>
              </div>
            </a>
          ))
      }
    </div>
  </div>
</Layout>