---
import { wikiRepository } from '@/lib/db/db';
import { DropDownMenu } from '@components/DropDownMenu';

const { role } = Astro.locals;

let staticLinks = [
  { href: '/wiki', text: 'Inicio' },
  { href: '/wiki/admin', text: 'Admin' }
];

if (role !== 'ADMIN') {
  staticLinks = staticLinks.filter((link) => link.href !== '/wiki/admin');
}

const pages = await wikiRepository.listArticles();

const articleLinks = pages.map((page) => ({
  href: `/wiki/manual/${page.slug}`,
  text: page.title
}));

const { pathname } = Astro.url;

function isActive(linkHref: string) {
  if (linkHref === '/wiki') {
    return pathname === '/wiki/' || pathname === '/wiki';
  }
  const pathRoute = pathname.split('/').pop();
  const linkRoute = linkHref.split('/').pop();

  return pathRoute === linkRoute;
}
---

<style>
  .active {
    @apply bg-primary text-primary-foreground;
  }
</style>

<aside
  id="main-sidebar"
  class="fixed inset-y-0 left-0 z-50 w-64 -translate-x-full border-r bg-background md:bg-muted/40 p-4 transition-transform duration-300 ease-in-out md:static md:translate-x-0"
>
  <nav>
    <h2 class="mb-2 px-4 text-lg font-semibold tracking-tight">Navegación</h2>
    <hr class="my-2 dark:border-slate-400 border-slate-600" />
    <ul>
      {
        staticLinks.map((link) => (
          <li class="">
            <a
              href={link.href}
              class:list={[
                'block rounded-md p-2 hover:bg-accent',
                {
                  active: isActive(link.href)
                }
              ]}
            >
              {link.text}
            </a>
          </li>
        ))
      }
    </ul>

    <h2 class="my-2 px-4 text-lg font-semibold tracking-tight">Artículos</h2>
    <hr class="mb-4 dark:border-slate-400 border-slate-600" />

    <ul class="flex flex-col">
      {
        articleLinks.map((link) => (
          <li class="flex justify-between">
            <a
              href={link.href}
              class:list={[
                'block rounded-md p-2 hover:bg-accent w-full',
                {
                  active: isActive(link.href)
                }
              ]}
            >
              {link.text}
            </a>
            <div class="flex items-center justify-center">
              <DropDownMenu
                client:only="react"
                slug={link.href.split('/').pop()!}
              />
            </div>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>
